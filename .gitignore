# ============================================
# IGS ACD Art Tools - .gitignore
# ============================================

# OS
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Node
node_modules/

# Config (contains GitHub PAT - DO NOT commit)
extension/config.json
config.json

# Build output
installer/*.exe

# Installer artifacts deployed alongside extension
extension/uninstall.exe
extension/cocos-importer/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temp / log files
*.tmp
*.log

# Maintainer-only local scripts (not for distribution)
sync-from-deployed.bat
sync-to-deployed.bat
